# --- API keys ---
GROQ_API_KEY=your_groq_key_here
GEMINI_API_KEY=your_gemini_key_here

# --- Models ---
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_MODEL=gemini-2.0-flash-lite
SCORING_GEMINI_MODEL=gemini-2.5-flash

# --- LLM transport tuning ---
LLM_TIMEOUT_SECONDS=30
LLM_MAX_TOKENS=512

# --- Pipeline tuning ---
N_SCORING_RUNS=1
MIN_RUBRICS=3
MAX_RUBRICS=6
SELECTION_TEMPERATURE=0.4
SCORING_TEMPERATURE=0
GAP_ANALYSIS_TEMPERATURE=0.3

# --- Input validation ---
MIN_WORDS=10
MAX_CHARS=15000
